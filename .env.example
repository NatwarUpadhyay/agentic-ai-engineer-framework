# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Language (Text Analytics)
AZURE_LANGUAGE_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your_language_key_here

# Azure AI Translator
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_KEY=your_translator_key_here
AZURE_TRANSLATOR_REGION=eastus

# Azure AI Vision (Computer Vision)
AZURE_VISION_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_VISION_KEY=your_vision_key_here

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH_SERVICE.search.windows.net
AZURE_SEARCH_KEY=your_search_admin_key_here
AZURE_SEARCH_INDEX=ai-framework-index

# Azure AI Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your_content_safety_key_here

# Azure Key Vault (optional)
AZURE_KEY_VAULT_URL=https://YOUR_KEYVAULT.vault.azure.net/

# OpenRouter (No Ollama / No heavy GPU needed!)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_MODEL=qwen/qwen3-vl-235b-a22b-thinking
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App Settings
APP_TITLE=Agentic AI Engineer Framework
APP_THEME=dark
